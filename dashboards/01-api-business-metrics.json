{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Request Rate (orders/s)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "targets": [
        {
          "expr": "sum(rate(orders_received_total{service_name=\"$service\"}[5m])) by (source)",
          "legendFormat": "{{source}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      }
    },
    {
      "title": "Error Rate (%)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "targets": [
        {
          "expr": "rate(errors_total{service_name=\"$service\"}[5m]) / rate(orders_received_total{service_name=\"$service\"}[5m]) * 100",
          "legendFormat": "error %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        }
      }
    },
    {
      "title": "Request Duration P95",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(request_duration_seconds_bucket{service_name=\"$service\"}[5m])) by (le, endpoint))",
          "legendFormat": "{{endpoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "title": "Cache Hit Rate",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "targets": [
        {
          "expr": "rate(cache_hits_total{service_name=\"$service\"}[5m]) / (rate(cache_hits_total{service_name=\"$service\"}[5m]) + rate(cache_misses_total{service_name=\"$service\"}[5m]))",
          "legendFormat": "hit rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.5
              },
              {
                "color": "green",
                "value": 0.8
              }
            ]
          }
        }
      }
    },
    {
      "title": "Cache Hits vs Misses",
      "type": "timeseries",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "targets": [
        {
          "expr": "rate(cache_hits_total{service_name=\"$service\"}[5m])",
          "legendFormat": "hits"
        },
        {
          "expr": "rate(cache_misses_total{service_name=\"$service\"}[5m])",
          "legendFormat": "misses"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      }
    },
    {
      "title": "Revenue (BRL)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "targets": [
        {
          "expr": "increase(revenue_total{service_name=\"$service\"}[1h])",
          "legendFormat": "last 1h"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyBRL"
        }
      }
    },
    {
      "title": "Active Requests",
      "type": "gauge",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "targets": [
        {
          "expr": "requests_active{service_name=\"$service\"}",
          "legendFormat": "active"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 10
              },
              {
                "color": "red",
                "value": 50
              }
            ]
          }
        }
      }
    },
    {
      "title": "Backend DB Query Duration P95",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(db_query_duration_seconds_bucket{service_name=\"sample-backend\"}[5m])) by (le, operation))",
          "legendFormat": "{{operation}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "title": "External Call Duration P95",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(external_call_duration_seconds_bucket{service_name=\"sample-backend\"}[5m])) by (le))",
          "legendFormat": "external P95"
        },
        {
          "expr": "rate(external_calls_total{service_name=\"sample-backend\"}[5m])",
          "legendFormat": "calls/s ({{status}})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "title": "Recent Traces",
      "type": "text",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 20
      },
