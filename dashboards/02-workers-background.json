  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Health Check Success Rate",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "targets": [
        {
          "expr": "1 - (rate(api_health_checks_failed_total{service_name=\"sample-process\"}[5m]) / rate(api_health_checks_total{service_name=\"sample-process\"}[5m]))",
          "legendFormat": "{{endpoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      }
    },
    {
      "title": "Health Check Duration (by endpoint)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(api_health_check_duration_seconds_bucket{service_name=\"sample-process\"}[5m])) by (le, endpoint))",
          "legendFormat": "{{endpoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "title": "Heavy Work \u2014 Throughput (items/s)",
